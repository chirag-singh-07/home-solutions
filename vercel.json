{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }

  ],
  "functions": {
    "server/index.ts": {
      "runtime": "nodejs20"
    }
  }

}

